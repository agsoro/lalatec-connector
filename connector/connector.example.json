{
  // Copy this file to connector.json and fill in your values.

  "thingsboard": {
    "host":          "your-thingsboard-host.example.com",
    "httpPort":      8080,
    "mqttPort":      1883,
    "adminEmail":    "tenant@thingsboard.org",
    "adminPassword": "YOUR_PASSWORD_HERE"
  },

  "polling": {
    // How often all devices are read, in seconds.
    "intervalSeconds": 30
  },

  // ── Monitoring Dashboard ──────────────────────────────────────────────────
  // Embedded read-only dashboard (Kestrel HTTP server on port 5000).
  // No authentication or security — for internal/controlled use only.
  "monitoring": {
    "enabled":     false,
    "port":        5000,
    "logBufferSize": 5000
  },

  // ── Connections ────────────────────────────────────────────────────────────
  // Define one entry per physical network endpoint.
  // Devices reference connections by "id".

  "connections": [
    {
      "id":   "modbus-building-a",
      "type": "modbus-tcp",
      "host": "192.168.1.100",
      "port": 502
    },
    {
      "id":   "modbus-building-b",
      "type": "modbus-tcp",
      "host": "192.168.1.101",
      "port": 502
    },
    {
      "id":   "bacnet-hvac",
      "type": "bacnet-ip",
      "host": "192.168.1.200",
      "port": 47808            // standard BACnet/IP port
    }
  ],

  // ── Devices ────────────────────────────────────────────────────────────────
  // Supported deviceTypes:
  //   "janitza"      → JanitzaReader  (Modbus TCP, requires slaveId)
  //   "abb"          → AbbReader      (Modbus TCP, requires slaveId)
  //   "sunspec"      → SunSpecReader  (Modbus TCP, discovery based, requires slaveId)
  //   "glueck"       → GlueckReader   (Modbus TCP, requires slaveId)
  //   "bacnet-generic" → BacnetReader (BACnet/IP, requires bacnetDeviceId + bacnet block)

  "devices": [

    // ── Janitza energy meter ──────────────────────────────────────────────────
    {
      "name":                "Main Meter Building A",
      "deviceType":          "janitza",
      "connectionId":        "modbus-building-a",
      "slaveId":             1,
      // Override the global polling interval for this device (optional).
      "pollIntervalSeconds": 30
    },
    {
      "name":                "Sub Meter Floor 2",
      "deviceType":          "janitza",
      "connectionId":        "modbus-building-b",
      "slaveId":             1,
      "pollIntervalSeconds": 30
    },

    // ── ABB energy meter ──────────────────────────────────────────────────────
    {
      "name":                "ABB Meter Zone C",
      "deviceType":          "abb",
      "connectionId":        "modbus-building-a",
      "slaveId":             106,
      "pollIntervalSeconds": 30
    },

    // ── SunSpec Solar Inverter ────────────────────────────────────────────────
    {
      "name":                "Fronius Inverter 1",
      "deviceType":          "sunspec",
      "connectionId":        "modbus-building-a",
      "slaveId":             1,
      "pollIntervalSeconds": 30
    },

    // ── Glück controller (Modbus TCP, read-only) ─────────────────────────────
    {
      "name":                "Glueck Controller Zone 1",
      "deviceType":          "glueck",
      "connectionId":        "modbus-building-a",
      "slaveId":             3,
      "pollIntervalSeconds": 30
      // Note: Write-back (writableRegisters) has been removed from Modbus devices.
      // Register addresses are now hardcoded in the driver code.
    },

    // ── BACnet/IP device with COV subscriptions ───────────────────────────────
    {
      "name":                "HVAC Controller AHU-01",
      "deviceType":          "bacnet-generic",
      "connectionId":        "bacnet-hvac",
      "bacnetDeviceId":      1001,

      // Per-device fallback poll interval.
      // For COV devices this controls how often fallback-polled objects are read.
      // For non-COV BACnet devices this is the regular poll interval.
      "pollIntervalSeconds": 30,

      "bacnet": {

        // Milliseconds to wait for a Who-Is / I-Am round-trip on startup.
        "whoIsTimeoutMs": 2000,

        // ── Object filter ──────────────────────────────────────────────────
        // All filter fields are optional. Omit a field to apply no restriction
        // on that dimension.
        "filter": {

          // Allowlist of object types to include. Mix and match freely:
          //   Short alias  →  "AI" | "AO" | "AV" | "BI" | "BO" | "BV"
          //                   "MI" | "MO" | "MV"
          //   Full name    →  "OBJECT_ANALOG_INPUT"  (case-insensitive)
          //   Numeric ID   →  "128"  (for proprietary/vendor types ≥ 128)
          // Omit or set to [] to include all object types.
          "objectTypes": [
            "AI", "AO", "AV",
            "BI", "BO", "BV",
            "MI", "MO", "MV"
          ],

          // Keep only objects with instance numbers in [min, max] (inclusive).
          // Omit to apply no instance range limit.
          "instanceRange": { "min": 0, "max": 9999 },

          // Regex applied to PROP_OBJECT_NAME.
          // Only objects whose name matches are kept. Omit to match all.
          "namePattern": ".",

          // Regex applied to PROP_OBJECT_NAME.
          // Objects whose name matches are removed. Omit to exclude nothing.
          "excludeNamePattern": "^(UNUSED|SPARE|TEST)",

          // Regex applied to PROP_DESCRIPTION.
          // PROP_DESCRIPTION is only read from the device when this is set.
          // Omit or set to null to skip description filtering entirely.
          "descriptionPattern": null,

          // Maximum number of objects to keep after all other filters.
          // Useful as a safety cap during initial integration.
          // 0 or null = unlimited.
          "maxObjects": 0
        },

        // ── Properties to read ─────────────────────────────────────────────
        // Use BacnetPropertyIds enum names (case-insensitive).
        "properties": {

          // Read on every poll → published as ThingsBoard time-series.
          "telemetry": [
            "PROP_PRESENT_VALUE",
            "PROP_STATUS_FLAGS",
            "PROP_RELIABILITY"
          ],

          // Read once on startup (and after each rediscovery) →
          // published as ThingsBoard device attributes.
          "attributes": [
            "PROP_OBJECT_NAME",
            "PROP_DESCRIPTION",
            "PROP_UNITS"
          ]
        },

        // ── Discovery schedule ─────────────────────────────────────────────
        "discovery": {
          // Run object discovery on the very first poll.
          "onStartup": true,

          // Repeat discovery every N minutes. 0 = never refresh.
          "refreshIntervalMinutes": 60
        },

        // ── Deziko Structured View hierarchy (opt-in) ──────────────────────
        "hierarchy": {
          "enabled":   true,
          "assetType": "BACnet Node"
        },

        // ── Change-of-Value subscriptions (opt-in) ─────────────────────────
        // When enabled the connector maintains a long-lived BACnet client and
        // receives push notifications from the device instead of polling.
        //
        //   enabled                 – set to true to activate COV for this device.
        //   lifetimeSeconds         – subscription TTL sent to the device (300 s default).
        //                             Subscriptions are auto-renewed 30 s before expiry.
        //   covIncrement            – min value change to trigger a notification (0 = any).
        //   confirmedNotifications  – true = device sends ACK-required notifications.
        //   attributePollRatePerMinute – how many attribute reads/min to drip-poll across
        //                             all objects (round-robin). 5 = 1 read every 12 s.
        //                             Attributes (PROP_UNITS, PROP_DESCRIPTION …) are read
        //                             continuously and pushed to ThingsBoard attributes.
        "cov": {
          "enabled":                  true,
          "lifetimeSeconds":          300,
          "covIncrement":             0.0,
          "confirmedNotifications":   false,
          "attributePollRatePerMinute": 5
        }
      },

      // ── Write-back (BACnet only – opt-in) ──────────────────────────────────
      // The connector subscribes to the appropriate MQTT topics on this device's
      // connection and forwards write commands to the BACnet device.
      //
      // Write-back targets any object discovered with PROP_PRIORITY_ARRAY
      // (commandable objects — AO, AV, BO, BV, MO, MV on Deziko).
      // Read-only sensor inputs (AI, BI, MI) are detected and rejected safely.
      //
      // RPC payload convention:
      //   { "method": "setValue", "params": { "key": "ao_3_supply_sp_value", "value": 21.0 } }
      //   Key format: {typeAlias}_{instance}_{sanitisedName}_{propSuffix}
      //   e.g. ao_3_supply_sp_value → OBJECT_ANALOG_OUTPUT:3, PROP_PRESENT_VALUE
      "writeback": {
        "sharedAttributes": true,   // write when a ThingsBoard shared attribute changes
        "rpc":              true    // write when a ThingsBoard server-side RPC fires
      }
    }
  ]
}
